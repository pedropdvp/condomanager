# Copiar para .env e ajustar conforme necessário.
# Usado pelo docker-compose.yml e pela aplicação (perfil dev).

DB_HOST=localhost
DB_PORT=3306
DB_NAME=condomanager
DB_USER=condomanager
DB_PASSWORD=condomanager
DB_ROOT_PASSWORD=root

SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# --- Email / SMTP (item F) -------------------------------------------------
# Com MAIL_ENABLED=false (default) os emails são apenas registados no log,
# permitindo testar recuperação de password e convocatórias sem servidor SMTP.
# Para enviar emails reais, definir MAIL_ENABLED=true e preencher as credenciais.
MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_AUTH=true
MAIL_STARTTLS=true
MAIL_FROM=nao-responder@condomanager.local
